{
  "name": "gam-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "GAM — Game Account Manager (standalone Vue 3 SPA, co-tenant on erp.local)",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:prod": "vite build --mode production",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preflight": "node scripts/preflight.mjs",
    "test:totp": "node tests/totp-rfc6238.mjs",
    "test:smoke": "node tests/smoke-http.mjs",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "deploy": "bash scripts/deploy.sh",
    "prod:setup": "sudo bash scripts/prod-setup.sh"
  },
  "dependencies": {
    "postal-mime": "^2.7.4",
    "socket.io-client": "^4.7.5",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^9.16.0",
    "eslint-plugin-vue": "^9.32.0",
    "globals": "^15.14.0",
    "jsdom": "^24.1.3",
    "tailwindcss": "^4.0.0",
    "vite": "^5.2.0",
    "vitest": "^1.6.1"
  }
}
