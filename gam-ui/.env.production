# ---- gam-ui prod (nginx static at /gam-ui/, same-origin as erp.local) ----
# Base path: assets + router must be rooted at /gam-ui/
VITE_BASE_URL=/gam-ui/

# Frappe co-tenant site name (shared session cookie with trader-ui)
VITE_FRAPPE_SITE=erp.local

# In prod /api + /socket.io are proxied by nginx on the same origin (port 80/443),
# so no separate socketio port is needed.
VITE_SOCKETIO_PORT=
